<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.AppTheme" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar" />
    <style name="AppTheme" parent="Base.AppTheme">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">?attr/isLightTheme</item>
        <item name="listPreferredItemPaddingEnd">20dp</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.AlertDialog</item>
    </style>

    <style name="ThemeOverlay.App.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="textAppearanceBodyMedium">@style/TextAppearance.App.DialogBody</item>
    </style>

    <style name="TextAppearance.App.DialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">17sp</item>
    </style>

    <style name="ToolbarSubtitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">13sp</item>
    </style>

    <!-- Smaller checkbox used in the toolbar overflow menu (default minTouchTargetSize is 48dp) -->
    <style name="Widget.App.MenuCheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="android:minHeight">20dp</item>
        <item name="android:minWidth">20dp</item>
    </style>

    <style name="ThemeOverlay.App.PopupMenu" parent="ThemeOverlay.Material3">
        <item name="checkboxStyle">@style/Widget.App.MenuCheckBox</item>
        <item name="android:checkboxStyle">@style/Widget.App.MenuCheckBox</item>
    </style>
</resources>
